---
import { FilterTabs } from "@components/atoms/filter-tabs";
import { AlbumCard } from "@components/features/albums";
import { PageHeader } from "@components/features/page-header";
import MainGridLayout from "@layouts/MainGridLayout.astro";

import { siteConfig } from "../config";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import { scanAlbums } from "../utils/album-scanner";

if (!siteConfig.featurePages.albums) {
	return Astro.redirect("/404/");
}

const albumsData = await scanAlbums();

// Collect all unique tags for filtering
const allTags = [...new Set(albumsData.flatMap((a) => a.tags || []))].sort();

const filterTabs = [
	{
		value: "all",
		label: i18n(I18nKey.albumsFilterAll),
		icon: "material-symbols:apps",
		count: albumsData.length,
	},
	...allTags.map((tag) => ({
		value: tag,
		label: tag,
		count: albumsData.filter(
			(a) => a.tags && a.tags.includes(tag),
		).length,
	})),
];

const title = i18n(I18nKey.albums);
const subtitle = i18n(I18nKey.albumsSubtitle);
